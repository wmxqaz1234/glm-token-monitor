{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "PlanGuard",
  "version": "0.1.0",
  "identifier": "com.planguard.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "label": "main",
        "width": 120,
        "height": 120,
        "minWidth": 120,
        "minHeight": 120,
        "maxWidth": 336,
        "maxHeight": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "center": true,
        "visible": true,
        "backgroundColor": "#00000000",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": false,
        "dragDropEnabled": true
      },
      {
        "label": "info-panel",
        "title": "用量详情",
        "width": 280,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "url": "src-tauri/info-panel.html",
        "backgroundColor": "#00000000",
        "shadow": false
      },
      {
        "label": "settings",
        "title": "PlanGuard 设置",
        "width": 480,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": false,
        "url": "src-tauri/settings.html",
        "backgroundColor": "#00000000",
        "shadow": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
