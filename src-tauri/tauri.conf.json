{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "glm-token-monitor",
  "version": "0.1.0",
  "identifier": "com.glmtoken.monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "label": "main",
        "width": 120,
        "height": 120,
        "minWidth": 120,
        "minHeight": 120,
        "maxWidth": 280,
        "maxHeight": 140,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "center": true,
        "visible": true,
        "backgroundColor": "#00000000",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": false,
        "dragDropEnabled": true
      },
      {
        "label": "info-panel",
        "title": "用量详情",
        "width": 280,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "url": "../windows/info-panel.html",
        "backgroundColor": "#00000000",
        "shadow": false
      },
      {
        "label": "settings",
        "title": "glm-token-monitor 设置",
        "width": 680,
        "height": 600,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false,
        "url": "../windows/settings.html",
        "backgroundColor": "#12141c",
        "shadow": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon-circle-16x16.png",
      "icons/icon-circle-32x32.png",
      "icons/icon-circle-48x48.png",
      "icons/icon-circle-64x64.png",
      "icons/icon-circle-128x128.png",
      "icons/icon-circle-256x256.png",
      "icons/icon-circle-512x512.png",
      "icons/icon.ico"
    ]
  }
}